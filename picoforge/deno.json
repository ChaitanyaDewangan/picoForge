{
  "tasks": {
    "dev": "deno task server:dev & deno task app:dev",
    "server:dev": "deno run --watch --env-file=.env --allow-net=127.0.0.1:7317,api.anthropic.com --allow-read --allow-write --allow-run=dotnet,forge-engine server/main.ts",
    "app:dev": "cd app && npm run dev",
    "check": "deno fmt --check && deno lint && deno task typecheck && deno task test",
    "typecheck": "deno check server/main.ts server/harness/orchestrator.ts scripts/setup.ts",
    "test": "deno test --allow-read --allow-write --allow-net=127.0.0.1 --allow-env server/harness/tests/",
    "bench": "deno bench --allow-read --allow-net=127.0.0.1",
    "setup": "deno run --allow-read --allow-write --allow-run --allow-net scripts/setup.ts",
    "db:reset": "deno run --allow-read --allow-write scripts/db_reset.ts",
    "harness:once": "deno run --env-file=.env --allow-net --allow-read --allow-write --allow-run server/harness/cli.ts"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "include": ["server/", "scripts/"]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "include": [
        "no-explicit-any",
        "no-unused-vars",
        "require-await"
      ]
    },
    "include": ["server/", "scripts/"]
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "lib": ["deno.ns", "dom"],
    "target": "ES2022"
  },
  "imports": {
    "hono": "npm:hono@^4",
    "hono/": "npm:hono@^4/",
    "zod": "npm:zod@^3",
    "ulid": "npm:ulid@^2",
    "@anthropic-ai/sdk": "npm:@anthropic-ai/sdk@^0.54.0"
  }
}
